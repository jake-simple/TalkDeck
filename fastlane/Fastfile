default_platform(:ios)

platform :ios do
  desc "App Store 메타데이터 업로드"
  lane :upload_metadata do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true
    )
  end

  desc "스크린샷 업로드"
  lane :upload_screenshots do
    deliver(
      skip_binary_upload: true,
      skip_metadata: true,
      force: true
    )
  end

  desc "메타데이터 + 스크린샷 모두 업로드"
  lane :upload_all do
    deliver(
      skip_binary_upload: true,
      force: true
    )
  end

  desc "앱 빌드 및 업로드"
  lane :release do
    build_app(
      scheme: "IceDeck",
      export_method: "app-store"
    )
    deliver(force: true)
  end
end
